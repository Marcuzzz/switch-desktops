<Window x:Class="SwitchDesktops.UI.CrossfadeOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Black"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        IsHitTestVisible="False"
        WindowStartupLocation="Manual">
    <Grid>
        <Image x:Name="FromImage" Stretch="Fill" Opacity="1" />
        <Image x:Name="ToImage"   Stretch="Fill" Opacity="0" />
    </Grid>
</Window>
