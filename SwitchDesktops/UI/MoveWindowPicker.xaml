<Window x:Class="SwitchDesktops.UI.MoveWindowPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Move Window to Desktop"
        Height="480" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select a window" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <ListBox x:Name="WindowList" Grid.Row="1" Background="#2A2A2A" Foreground="White" BorderThickness="0"/>

        <TextBlock Grid.Row="2" Text="Move to" FontSize="14" Margin="0,12,0,4"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <ComboBox x:Name="DesktopCombo" Width="200" Margin="0,0,8,0"/>
            <Button x:Name="MoveButton" Content="Move" Padding="16,6" Click="OnMove"/>
            <Button x:Name="CancelButton" Content="Cancel" Padding="16,6" Margin="8,0,0,0" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
